# ============================================================================
#  Khuta — secrets template. Copy to `.env` and fill in real values.
#  `.env` is gitignored; this file is safe to commit.
# ============================================================================

# ─── Android release signing ────────────────────────────────────────────────
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_PASSWORD=
ANDROID_KEY_ALIAS=
ANDROID_KEYSTORE_FILE=release-keystore.jks

# ─── Firebase Admin / backend (path to service account JSON, kept out of repo) ─
GOOGLE_APPLICATION_CREDENTIALS=./secrets/khuta-1febc-service-account.json

# ─── Firebase CLIENT config (NOT secret — already in firebase_options.dart) ──
FIREBASE_PROJECT_ID=khuta-1febc
FIREBASE_PROJECT_NUMBER=706590459247
FIREBASE_WEB_API_KEY=
FIREBASE_ANDROID_API_KEY=
FIREBASE_IOS_API_KEY=
FIREBASE_ANDROID_APP_ID=
FIREBASE_IOS_APP_ID=
FIREBASE_WEB_APP_ID=
